APP_NAME="CMF - Control y Monitoreo de Fuerza Laboral"
APP_ENV=production
APP_KEY=  # ← Generar con: php artisan key:generate
APP_DEBUG=false
APP_URL=https://tu-dominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# Base de datos
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cmf_production
DB_USERNAME=cmf_user
DB_PASSWORD=  # ← Contraseña fuerte

# Cache
CACHE_STORE_PRIMARY=redis
CACHE_STORE_FALLBACK=file
CACHE_PREFIX=cmf_prod_

# Queue
QUEUE_CONNECTION=database

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

# Redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=  # ← Contraseña Redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Rate Limiting (PRODUCCIÓN - más estricto)
RATE_LIMIT_LOGIN=3
RATE_LIMIT_API=60
RATE_LIMIT_NFC=30
RATE_LIMIT_HEALTH=10
RATE_LIMIT_LOGIN_LOCKOUT=30

# Security
FORCE_HTTPS=true
MAX_LOGIN_ATTEMPTS=5

# Logging (PRODUCCIÓN - solo errores)
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=error
LOG_CACHE_FALLBACK=true
LOG_FAILED_LOGINS=true
LOG_NFC_EVENTS=true
LOG_QUEUE_FAILURES=true

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=  # ← Tu email
MAIL_PASSWORD=  # ← App Password de Gmail
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=  # ← Email remitente
MAIL_FROM_NAME="${APP_NAME}"

# NUNCA COMMITEAR:
# - APP_KEY
# - DB_PASSWORD
# - REDIS_PASSWORD
# - MAIL_PASSWORD
