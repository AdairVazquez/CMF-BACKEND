# XAMPP Windows - Sin Redis
APP_NAME="CMF - Control y Monitoreo de Fuerza Laboral"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# MySQL local
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=system_core_api
DB_USERNAME=root
DB_PASSWORD=

# SIN REDIS - Usar archivos y base de datos
CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
REDIS_ENABLED=false

# Desarrollo
HEALTH_EXPOSE_METRICS=true
LOG_LEVEL=debug
