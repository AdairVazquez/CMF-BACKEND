APP_NAME="CMF - Control y Monitoreo de Fuerza Laboral"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

# Base de datos (MySQL siempre disponible)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=system_core_api
DB_USERNAME=root
DB_PASSWORD=

# Cache - Sistema intenta PRIMARY, si falla usa FALLBACK automáticamente
CACHE_STORE_PRIMARY=redis
CACHE_STORE_FALLBACK=file
CACHE_PREFIX=cmf_

# Queue - Sistema intenta PRIMARY, si falla usa FALLBACK automáticamente
QUEUE_CONNECTION_PRIMARY=redis
QUEUE_CONNECTION_FALLBACK=database

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis (Sistema detecta automáticamente si está disponible)
REDIS_AUTO_DETECT=true
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_TIMEOUT=100
REDIS_RETRY_AFTER=3
REDIS_RECONNECT_INTERVAL=300

# Rate Limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_API=60
RATE_LIMIT_NFC=30
RATE_LIMIT_HEALTH=10
RATE_LIMIT_LOGIN_LOCKOUT=15

# NFC Devices
NFC_DEVICE_TIMEOUT=5
NFC_MAX_EVENTS=30
NFC_REQUIRE_DEVICE_KEY=true

# Health Check
HEALTH_EXPOSE_METRICS=true
HEALTH_CRITICAL_SPACE=100
HEALTH_WARNING_SPACE=500

# Cache Warming
CACHE_WARMING_ENABLED=true

# Security
FORCE_HTTPS=false
MAX_LOGIN_ATTEMPTS=5

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug
LOG_CACHE_FALLBACK=true
LOG_FAILED_LOGINS=true
LOG_NFC_EVENTS=true
LOG_QUEUE_FAILURES=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@cmf.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
